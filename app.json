{
  "expo": {
    "name": "Garden Manager",
    "slug": "garden-manager",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "garden-manager",
    "splash": {
      "backgroundColor": "#2D5A3D",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omnisolutions.gardenmanager",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to get accurate weather data for your garden."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D5A3D"
      },
      "package": "com.omnisolutions.gardenmanager",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Garden Manager to access your location for weather data."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "419ee6b5-3360-457d-b522-a9c39c18e733"
      }
    }
  }
}
